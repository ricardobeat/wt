#!/usr/bin/env bash

set -euo pipefail

MAIN=$(dirname $(realpath $(git rev-parse --git-common-dir)))
CONFIG_SLUG=$(echo "$MAIN" | sed 's|^/||; s|/|-|g')
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/wt/$CONFIG_SLUG/wt.toml"

settings() {
  mkdir -p "$(dirname "$CONFIG_FILE")"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<'TOML'
# wt settings for this repo

# command run once after a new worktree is created
# prepare = "pnpm install"

# extra untracked paths to copy into new worktrees (space-separated globs)
# copy = "node_modules .venv"

# directory where new worktrees are created (default: <repo>/.worktrees)
# supports ~ expansion; the branch name is appended automatically
# worktrees_dir = "~/worktrees/myrepo"
TOML
  fi
  # unquoted so EDITOR="code -w" and friends split into command + args
  ${VISUAL:-${EDITOR:-vi}} "$CONFIG_FILE"
}

config_set() {
  local key=${1:?usage: wt set <key> <value>}
  local value=${2:?usage: wt set <key> <value>}
  mkdir -p "$(dirname "$CONFIG_FILE")"
  if [[ -f "$CONFIG_FILE" ]] && grep -q "^${key}[[:space:]]*=" "$CONFIG_FILE"; then
    # portable in-place edit (BSD and GNU sed disagree on -i)
    local tmp
    tmp=$(mktemp)
    sed "s|^${key}[[:space:]]*=.*|${key} = \"${value}\"|" "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  else
    echo "${key} = \"${value}\"" >> "$CONFIG_FILE"
  fi
}

worktrees_dir() {
  local dir
  if [[ -f "$CONFIG_FILE" ]]; then
    dir=$(sed -n 's/^worktrees_dir[[:space:]]*=[[:space:]]*"\(.*\)"/\1/p' "$CONFIG_FILE")
  fi
  if [[ -n "${dir:-}" ]]; then
    # expand leading ~
    printf '%s' "${dir/#\~/$HOME}"
  else
    printf '%s' "$MAIN/.worktrees"
  fi
}

run_prepare() {
  [[ -f "$CONFIG_FILE" ]] || return 0
  local cmd
  cmd=$(sed -n 's/^prepare[[:space:]]*=[[:space:]]*"\(.*\)"/\1/p' "$CONFIG_FILE")
  [[ -z "$cmd" ]] && return 0
  echo "prepare: $cmd" >&2
  eval "$cmd"
}

enter_shell() {
  local wt_zdir="$HOME/.cache/wt-shell"
  mkdir -p "$wt_zdir"
  cat > "$wt_zdir/.zshrc" <<'ZSHRC'
ZDOTDIR=$HOME
[[ -f ~/.zshrc ]] && source ~/.zshrc
PROMPT="[wt] $PROMPT"
ZSHRC
  ZDOTDIR="$wt_zdir" exec "$SHELL"
}

setup() {
  WORKTREE=$(pwd)

  # Patterns for untracked paths to clone from the main worktree. Extend
  # per-repo with a space-separated `copy = "..."` entry in the config
  # (e.g. wt set copy "node_modules .venv").
  local -a patterns=( ".env*" )
  if [[ -f "$CONFIG_FILE" ]]; then
    local extra
    extra=$(sed -n 's/^copy[[:space:]]*=[[:space:]]*"\(.*\)"/\1/p' "$CONFIG_FILE")
    if [[ -n "$extra" ]]; then
      local -a extra_arr
      read -ra extra_arr <<<"$extra"
      patterns+=( "${extra_arr[@]}" )
    fi
  fi

  # --others lists untracked files; --directory collapses untracked dirs
  # (like node_modules/) into a single entry so we can clone them whole.
  git -C "$MAIN" ls-files --others --directory | while read -r f; do
    local entry="${f%/}"        # drop trailing slash on collapsed dirs
    local pat matched=0
    for pat in "${patterns[@]}"; do
      if [[ $entry == $pat || ${entry##*/} == $pat ]]; then
        matched=1
        break
      fi
    done
    [[ $matched -eq 1 ]] || continue

    local src="$MAIN/$f"
    local dest="$WORKTREE/$f"
    if [[ -e "$dest" ]]; then
      echo "skip: $f" >&2
      continue
    fi

    mkdir -p "$(dirname "$dest")"
    echo "copy: $f" >&2
    # prefer copy-on-write where the filesystem supports it, else plain copy
    cp --reflink=auto -R "$src" "$dest" 2>/dev/null \
      || cp -cR "$src" "$dest" 2>/dev/null \
      || cp -R "$src" "$dest"
  done

  run_prepare
}

create() {
  local NAME=$1
  local WT_DIR
  WT_DIR=$(worktrees_dir)
  local DEST="$WT_DIR/$NAME"
  local EXISTING
  EXISTING=$(git -C "$MAIN" worktree list --porcelain | awk -v ref="refs/heads/$NAME" '
    /^worktree / { wt=substr($0, 10) }
    /^branch / && $2==ref && !found { print wt; found=1 }
  ')
  local NEW=0
  if [[ -n "$EXISTING" ]]; then
    DEST="$EXISTING"
    [[ "$DEST" != "$WT_DIR/"* ]] && echo "note: jumping to existing worktree at $DEST" >&2
  elif [[ ! -d "$DEST" ]]; then
    git worktree add "$DEST" -b "$NAME" >&2 2>&1 ||
      git worktree add "$DEST" "$NAME" >&2 2>&1 ||
      { echo "failed to create worktree for $NAME" >&2; exit 1; }
    NEW=1
  fi
  cd "$DEST"
  [[ $NEW -eq 1 ]] && setup </dev/tty
  enter_shell
}

# Classify a worktree by the directory tree it lives under. The path is the
# ground-truth signal: each assistant creates worktrees beneath its own fixed
# root (branch names are user-mutable and unreliable). Add new assistants here.
# Echoes "<base>\t<label>"; an empty label means untagged (our own worktrees, or
# anything we don't recognise) — still listed and still cd-able by branch. Base
# (always non-empty) goes first so the optional label can't get IFS-collapsed.
detect_tool() {
  case $1 in
    "$MAIN/.claude/worktrees/"*) printf '%s\t%s' "$MAIN/.claude/worktrees/" "claude" ;;
    "$HOME/.codex/worktrees/"*)  printf '%s\t%s' "$HOME/.codex/worktrees/"  "codex" ;;
    *)                           printf '%s\t%s' "$(worktrees_dir)/"        "" ;;
  esac
}

list_worktrees() {
  local MAIN_NAME
  MAIN_NAME=$(basename "$MAIN")

  local C_CLAUDE=$'\033[38;5;205m'
  local C_CODEX=$'\033[36m'
  local C_BRANCH=$'\033[32m'
  local C_DIM=$'\033[2m'
  local C_RESET=$'\033[0m'

  git -C "$MAIN" worktree list --porcelain | awk '
    /^worktree / { wt = substr($0, 10) }
    /^branch / {
      name = $2
      sub(/^refs\/heads\//, "", name)
      print wt "\t" $2 "\t" name
    }
  ' | while IFS=$'\t' read -r wt ref branch; do
    local tool base dir
    IFS=$'\t' read -r base tool <<<"$(detect_tool "$wt")"
    dir="${wt#"$base"}"
    case $tool in
      "")
        display=$(printf '%-10s %s%s%s' "" "$C_BRANCH" "$branch" "$C_RESET")
        ;;
      claude)
        display=$(printf '%s%-10s%s %s%s%s' "$C_CLAUDE" "[claude]" "$C_RESET" "$C_BRANCH" "$branch" "$C_RESET")
        if [[ "$dir" != "$branch" && "$branch" != *"/$dir" ]]; then
          display="$display ${C_DIM}${dir}${C_RESET}"
        fi
        ;;
      codex)
        dir="${dir%/$MAIN_NAME}"
        display=$(printf '%s%-10s%s %s%s%s %s%s%s' "$C_CODEX" "[codex]" "$C_RESET" "$C_BRANCH" "$branch" "$C_RESET" "$C_DIM" "$dir" "$C_RESET")
        ;;
    esac
    ts=$(git -C "$MAIN" log -1 --format=%ct "$ref" 2>/dev/null) || ts=0
    printf '%s\t%s\t%s\n' "$ts" "$branch" "$display"
  done | sort -rn | cut -f2-
}

remove() {
  DEST=$(pwd)
  if [[ ! -d "$DEST" ]]; then
    echo "worktree not found: $1" >&2
    exit 1
  fi
  git worktree remove "$DEST"
  exit
}

select_worktree() {
  if command -v fzf &>/dev/null; then
    local SELECTED BRANCH
    SELECTED=$(list_worktrees | fzf --ansi --delimiter=$'\t' --with-nth=2 --height=~20) || exit 0
    BRANCH=$(printf '%s' "$SELECTED" | cut -f1)
    create "$BRANCH"
  else
    echo "available worktrees:" >&2
    list_worktrees | cut -f2- || echo "  (none)" >&2
  fi
}

rename() {
  local NEW_NAME=${1:?usage: wt rename <new-name>}
  local CURRENT_BRANCH
  CURRENT_BRANCH=$(git symbolic-ref --short HEAD)

  # Fail if the branch is already pushed to the remote
  if git rev-parse --verify "refs/remotes/origin/$CURRENT_BRANCH" &>/dev/null; then
    echo "error: branch '$CURRENT_BRANCH' is already pushed to origin, refusing to rename" >&2
    exit 1
  fi

  local OLD_DIR WT_DIR
  OLD_DIR=$(pwd)
  WT_DIR=$(worktrees_dir)
  if [[ "$OLD_DIR" != "$WT_DIR/"* ]]; then
    echo "error: not inside a worktree" >&2
    exit 1
  fi

  git branch -m "$NEW_NAME"
  local NEW_DIR="$WT_DIR/$NEW_NAME"
  git worktree move "$OLD_DIR" "$NEW_DIR"
  cd "$NEW_DIR"
  enter_shell
}

usage() {
  cat <<'EOF'
usage: wt [command] [args]

  wt                    interactive worktree picker (requires fzf)
  wt <branch>           switch to or create a worktree for <branch>
  wt remove | end       remove the current worktree
  wt rename <name>      rename the current branch and worktree directory
  wt setup              copy tracked files and run prepare command
  wt settings           open the per-repo config file in $EDITOR
  wt set <key> <value>  set a config value (prepare, copy, worktrees_dir)
  wt --help | help      show this message
EOF
}

case ${1:-} in
  setup)          setup ;;
  set)            config_set "${2:-}" "${3:-}" ;;
  settings)       settings ;;
  rename)         rename "${2:-}" ;;
  remove|end)     remove ;;
  exit)           exit ;;
  --help|help)    usage ;;
  "")             select_worktree ;;
  *)              create "$1" ;;
esac
